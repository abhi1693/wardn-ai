WARDN_ENVIRONMENT=local
WARDN_LOG_LEVEL=INFO
WARDN_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wardn
WARDN_CORS_ORIGINS=http://localhost:3000
WARDN_AUTH_MODE=local
WARDN_FRONTEND_BASE_URL=http://localhost:3000
# Set WARDN_AUTH_MODE=oidc and configure these for external-provider sign-in.
# Register http://localhost:3000/api/auth/oidc/callback as the redirect URI unless
# WARDN_OIDC_REDIRECT_URI is explicitly set.
WARDN_OIDC_PROVIDER_NAME=External identity provider
WARDN_OIDC_ISSUER_URL=
WARDN_OIDC_CLIENT_ID=
WARDN_OIDC_CLIENT_SECRET=
WARDN_OIDC_REDIRECT_URI=
WARDN_OIDC_SCOPES=openid email profile
WARDN_OIDC_ALLOWED_EMAIL_DOMAINS=
WARDN_OIDC_SUPERUSER_EMAILS=
