WARDN_ENVIRONMENT=local
WARDN_LOG_LEVEL=INFO
WARDN_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wardn
WARDN_DATABASE_POOL_SIZE=5
WARDN_DATABASE_MAX_OVERFLOW=10
WARDN_DATABASE_POOL_TIMEOUT_SECONDS=30
WARDN_DATABASE_POOL_RECYCLE_SECONDS=1800
WARDN_DATABASE_POOL_PRE_PING=true
WARDN_DATABASE_POOL_USE_LIFO=true
WARDN_CORS_ORIGINS=http://localhost:3000
WARDN_AUTH_MODE=local
WARDN_SESSION_COOKIE_NAME=wardn_session
WARDN_API_TOKEN_USAGE_UPDATE_INTERVAL_SECONDS=300
WARDN_FRONTEND_BASE_URL=http://localhost:3000
# Set WARDN_AUTH_MODE=oidc and configure these for external-provider sign-in.
# Register http://localhost:8000/api/v1/auth/oidc/callback as the redirect URI unless
# WARDN_OIDC_REDIRECT_URI is explicitly set.
WARDN_OIDC_PROVIDER_NAME=External identity provider
WARDN_OIDC_ISSUER_URL=
WARDN_OIDC_CLIENT_ID=
WARDN_OIDC_CLIENT_SECRET=
WARDN_OIDC_REDIRECT_URI=
WARDN_OIDC_SCOPES=openid email profile
WARDN_OIDC_ALLOWED_EMAIL_DOMAINS=
WARDN_OIDC_SUPERUSER_EMAILS=
# Operator-managed OpenBao profiles bind credentials to a destination. Credential paths in the
# profile JSON must be relative to this read-only root.
WARDN_OPENBAO_AUTH_FILE_ROOT=/var/run/secrets
WARDN_OPENBAO_AUTH_PROFILES_JSON={}
WARDN_SECRET_CLEANUP_WORKER_POLL_INTERVAL_SECONDS=2
WARDN_SECRET_CLEANUP_WORKER_LEASE_SECONDS=120
WARDN_SECRET_CLEANUP_PROVISIONING_GRACE_SECONDS=300
WARDN_SECRET_CLEANUP_WORKER_RETRY_BASE_SECONDS=15
WARDN_SECRET_CLEANUP_WORKER_RETRY_MAX_SECONDS=900
# Outbound OpenBao, catalog, and remote MCP requests allow public HTTPS on port 443 by default.
# Add exact internal hosts and any nonstandard ports explicitly. HTTP remains disabled by default.
WARDN_OUTBOUND_HTTP_ALLOW_HTTP=false
WARDN_OUTBOUND_HTTP_ALLOWED_PORTS=443
WARDN_OUTBOUND_HTTP_PRIVATE_HOST_ALLOWLIST=
# Optional token used only by the authenticated GitHub repository metadata importer.
WARDN_GITHUB_TOKEN=
# Cluster-wide fixed-window limit for metadata imports within each organization.
WARDN_GITHUB_METADATA_IMPORT_RATE_LIMIT=10
WARDN_GITHUB_METADATA_IMPORT_RATE_WINDOW_SECONDS=60
# MCP jobs run in a separate worker process locally. Production workers must be deployed in an
# isolated container or pod before setting this value to container.
WARDN_MCP_JOB_WORKER_ISOLATION=process
WARDN_MCP_JOB_WORKER_POLL_INTERVAL_SECONDS=2
WARDN_MCP_JOB_WORKER_LEASE_SECONDS=120
WARDN_MCP_JOB_WORKER_HEARTBEAT_SECONDS=30
WARDN_MCP_JOB_WORKER_RETRY_BASE_SECONDS=15
WARDN_MCP_JOB_WORKER_RETRY_MAX_SECONDS=900
WARDN_MCP_RUNTIME_INVOCATION_STALE_SECONDS=600
